# Copy this file to `.env`.

# --- Demo mode -------------------------------------------------------------
# Set to true to run the CRM with mocked sample data and NO backend:
# any email/password logs you in. Great for demos/presentations.
# Leave it out (or set false) once you have real Supabase keys below.
VITE_DEMO_MODE=true

# --- Supabase (only needed when VITE_DEMO_MODE is not true) -----------------
# Find both under Supabase → Project Settings → API.
VITE_SUPABASE_URL=https://dnxvvvjivxmaxlkoappr.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_DnXXfeEl_qevlWeXDHe3ww_rMu54FjS

# --- AI assistant LLM engine (optional) ------------------------------------
# Leave false to use the built-in grounded assistant (works with no backend).
# Set true ONLY after deploying the backend proxy in ./server (see server/README.md)
# — the Anthropic API key lives on the server, never in this frontend file.
VITE_LLM_ENABLED=false
# Same-origin path nginx forwards to the Node proxy (default shown).
VITE_AI_PROXY_URL=/api/ai
