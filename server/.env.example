# Copy to `.env` on the SERVER only. NEVER commit the real key or upload it to GitHub.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Model id. Cheapest: claude-haiku-4-5-20251001 · balanced: claude-sonnet-5 · best: claude-opus-4-8
ANTHROPIC_MODEL=claude-sonnet-5

# Comma-separated allowed origins (your live site).
ALLOWED_ORIGIN=https://crm.sarvadesk.com

# Local port nginx forwards to. Keep it bound to 127.0.0.1 (see index.js).
PORT=8787

# Hard cap on tokens per reply — bounds cost.
MAX_TOKENS=1024
